DEBUG=1
SECRET_KEY=change-me
TIME_ZONE=UTC

HOST_PROJECT_DIR=/absolute/path/to/Hackathon

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
PUBLIC_BASE_URL=http://localhost:8000

RESEND_API_KEY=
RESEND_FROM_EMAIL=Reinforce Finance <onboarding@resend.dev>
RESEND_TIMEOUT_SECONDS=10
EMAIL_VERIFICATION_TTL_HOURS=48

POSTGRES_DB=hackathon
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

SUBMISSION_MAX_UPLOAD_MB=32
ZIP_MAX_UNPACKED_MB=256
ZIP_MAX_FILES=2000
ZIP_MAX_COMPRESSION_RATIO=250

RUNNER_IMAGE=hackathon-runner:local
RUNNER_IMAGE_ALLOWLIST=hackathon-runner:local
RUNNER_TIMEOUT_SECONDS=3600
RUNNER_CPUS=1
RUNNER_MEMORY=16g
RUNNER_PIDS_LIMIT=256
RUNNER_TMPFS_SIZE=64m
RUNNER_USER=65534:65534
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_ARTIFICIAL_DELAY_SECONDS=0

TASK_DATA_DOWNLOAD_PATH=/absolute/path/to/Hackathon/datasets/test.parquet
TASK_DATA_DOWNLOAD_NAME=reinforce-market-action-data.parquet
